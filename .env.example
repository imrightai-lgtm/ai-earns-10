# Скопируй этот файл в .env и заполни значения.
# .env в репозиторий НЕ коммитится (см. .gitignore). .env.example — да, это шаблон.
#
# Правила:
#   - только отдельные «эксперимент»-аккаунты, не личные логины оператора;
#   - НИКОГДА не клади сюда seed-фразу/приватный ключ кошелька (кошелёк только на приём);
#   - выдавай токенам минимум прав.

# --- Telegram (свой канал) ---
# Токен бота от @BotFather; канал, где бот назначен администратором.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=@your_channel

# --- GitHub (свой опенсорс) ---
# Personal Access Token (fine-grained) с доступом к нужному репозиторию.
GITHUB_TOKEN=

# --- Cloudflare Pages (для автономного деплоя агентом без интерактивного входа) ---
# Токен с правом "Cloudflare Pages: Edit" и ID аккаунта.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Метрики (для tools/check-metrics.mjs) ---
# Cloudflare Web Analytics. Нужны: ОТДЕЛЬНЫЙ токен с правом Account Analytics: Read (не деплойный),
# CLOUDFLARE_ACCOUNT_ID (выше) и site tag (Analytics & Logs → Web Analytics → site tag).
CF_ANALYTICS_API_TOKEN=
CF_ANALYTICS_SITE_TAG=
# GitHub-репозиторий для подсчёта звёзд/форков, формат owner/name.
GITHUB_REPO=

# --- Nostr (свободный открытый протокол; агент ведёт сам из своего ключа) ---
# NOSTR_NSEC создаётся автоматически командой `node tools/post-nostr.mjs keygen`
# и дописывается в .env. Это СЕКРЕТ (ключ подписи постов) — не коммить и не публикуй.
# Кошелёк тут НИ ПРИ ЧЁМ: это ключ идентичности в Nostr, не доступ к средствам.
NOSTR_NSEC=
# Опц.: свои релеи через запятую (по умолчанию damus/nos.lol/primal/band).
NOSTR_RELAYS=
# Профиль (kind:0), опц.:
NOSTR_NAME=
NOSTR_ABOUT=
NOSTR_WEBSITE=
# Lightning-адрес для приёма zaps (опц.; требует создания no-KYC кошелька — шаг оператора).
NOSTR_LUD16=
